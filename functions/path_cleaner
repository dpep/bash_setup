# Path Cleaner
#
# Tidy up path environment variables - dedup, compact, preserve order


path_cleaner() {
    # default to the usual suspects
    if [ "$#" -eq 0 ]; then
        set -- CDPATH PATH PYTHONPATH
    fi

    local name val
    for name in "$@"; do
        [ -n "$name" ] || continue

        # read the variable's current value indirectly
        eval "val=\${$name}"

        # filter non-existent directories, drop duplicates, preserve order
        val=$(
            printf '%s' "$val" | tr ':' '\n' | while IFS= read -r entry; do
                [ -d "$entry" ] && printf '%s\n' "$entry"
            done | awk '!seen[$0]++' ORS=:
        )

        # drop trailing colon
        val=${val%:}

        # write the cleaned value back, or drop if empty
        if [ -z "$val" ]; then
            unset "$name"
        else
            eval "$name=\"\$val\""
        fi
    done
}
