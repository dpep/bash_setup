#!/bin/sh

# Open files or GitHub links in editor

EEDITOR=${EEDITOR:-$EDITOR}

edit() {
  # strip github blob URL prefix, if present
  input=$(printf '%s' "$1" | sed -E 's,.*github\.com/[^/]+/[^/]+/blob/[^/]+/,,')

  # pull the line number from the first ':' or '#L' ref, if any
  line_num=$(printf '%s' "$input" | sed -nE 's/^[^:#]*(#L|:)([0-9]+).*/\2/p')

  # strip line ref to leave the bare path
  path=$(printf '%s' "$input" | sed -E 's/(#L|:)[0-9]+.*$//')

  if [ -n "$line_num" ]; then
    if [ ! -f "$path" ]; then
      echo "File not found: $path" >&2
      exit 1
    fi

    $EEDITOR "$path:$line_num"
  else
    $EEDITOR "$path"
  fi
}

if [ -n "$1" ]; then
  # use command line arguments
  edit "$@"
else
  # read from stdin
  while IFS= read -r line; do
    edit "$line"
  done
fi
